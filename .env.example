# ============================================
# QUANTUM STUDIO - Environment Variables
# ============================================

# Supabase (Required)
# Get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Pexels API (Required for photos)
# Get from: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your-pexels-api-key-here

# Unsplash API (Optional)
# Get from: https://unsplash.com/developers
VITE_UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# Pixabay API (Optional)
# Get from: https://pixabay.com/api/docs/
VITE_PIXABAY_API_KEY=your-pixabay-api-key-here

# Firebase (Required for Auth)
# Get from: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id-here
